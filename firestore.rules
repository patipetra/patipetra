rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı fonksiyonlar ────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(field) {
      return isAuth() && resource.data[field] == request.auth.uid;
    }

    // ─── Kullanıcılar ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth();
      allow write:  if isAuth() && request.auth.uid == userId;
    }

    // ─── İlanlar ──────────────────────────────────────────────────────────────
    match /listings/{doc} {
      allow read:         if true;
      allow create:       if isAuth();
      allow update,delete:if isAuth() && (isOwner('ownerId') || isAdmin());
    }

    // ─── Petler ───────────────────────────────────────────────────────────────
    match /pets/{doc} {
      allow read,write: if isAuth() &&
        (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ─── Topluluklar ──────────────────────────────────────────────────────────
    match /communities/{doc} {
      allow read:          if true;
      allow create:        if isAuth();
      allow update,delete: if isAuth() && (isOwner('createdBy') || isAdmin());
    }

    // ─── Gönderiler ───────────────────────────────────────────────────────────
    match /posts/{doc} {
      allow read:          if true;
      allow create:        if isAuth();
      allow update,delete: if isAuth() && (isOwner('authorId') || isAdmin());
    }

    match /posts/{postId}/comments/{doc} {
      allow read:   if true;
      allow create: if isAuth();
      allow delete: if isAuth() && (isOwner('authorId') || isAdmin());
    }

    match /posts/{postId}/likes/{doc} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ─── Hizmetler ────────────────────────────────────────────────────────────
    match /services/{doc} {
      allow read:          if true;
      allow create:        if isAuth();
      allow update,delete: if isAuth() && (
        isOwner('ownerId') || isOwner('userId') || isAdmin()
      );
    }

    // ─── Randevular ───────────────────────────────────────────────────────────
    match /appointments/{doc} {
      allow read:   if isAuth() && (
        resource.data.userId         == request.auth.uid ||
        resource.data.serviceOwnerId == request.auth.uid ||
        resource.data.vetId          == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userId         == request.auth.uid ||
        resource.data.serviceOwnerId == request.auth.uid ||
        resource.data.vetId          == request.auth.uid ||
        isAdmin()
      );
    }

    // ─── Yorumlar ─────────────────────────────────────────────────────────────
    match /reviews/{doc} {
      allow read:   if true;
      allow create: if isAuth();
      allow delete: if isAuth() && (isOwner('userId') || isOwner('authorId') || isAdmin());
    }

    // ─── Blog ─────────────────────────────────────────────────────────────────
    match /blogSubmissions/{doc} {
      allow create:        if true;
      allow read,update,delete: if isAdmin();
    }

    match /blogPosts/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Veterinerler ─────────────────────────────────────────────────────────
    match /vets/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /vetQuestions/{doc} {
      allow read:   if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        isOwner('vetId') || isOwner('userId') || isAdmin()
      );
    }

    match /vetApplications/{doc} {
      allow create:        if isAuth();
      allow read,update,delete: if isAuth() && (isOwner('userId') || isAdmin());
    }

    match /vetContracts/{doc} {
      allow read:  if isAuth() && (isOwner('vetUserId') || isAdmin());
      allow write: if isAdmin();
    }

    // ─── Mesajlaşma ───────────────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read:   if isAuth() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() &&
        request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read:   if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    // ─── Bildirimler ──────────────────────────────────────────────────────────
    match /notifications/{doc} {
      allow read,update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create:      if isAuth();
      allow delete:      if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Favoriler ────────────────────────────────────────────────────────────
    match /favorites/{doc} {
      allow read:   if isAuth() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─── Premium Kodları ──────────────────────────────────────────────────────
    match /premiumCodes/{doc} {
      allow read:   if isAdmin() || (isAuth() && doc == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // ─── Site Ayarları ────────────────────────────────────────────────────────
    match /siteSettings/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Popup ────────────────────────────────────────────────────────────────
    match /popups/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Ürünler ─────────────────────────────────────────────────────────────
    match /products/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Planlar ─────────────────────────────────────────────────────────────
    match /plans/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Admin — tüm diğer koleksiyonlar ─────────────────────────────────────
    match /{document=**} {
      allow read,write: if isAdmin();
    }
  }
}
