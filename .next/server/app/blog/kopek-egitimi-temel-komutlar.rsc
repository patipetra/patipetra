ame":"absolute top-[84px] left-4 sm:left-8","children":["$","$L3",null,{"href":"/blog","className":"text-sm text-white/70 hover:text-white transition-colors","children":"← Blog'a Dön"}]}]]}],["$","div",null,{"className":"max-w-[1100px] mx-auto px-4 sm:px-8 py-10","children":["$","div",null,{"className":"grid lg:grid-cols-[1fr_.32fr] gap-10","children":[["$","article",null,{"children":[["$","div",null,{"className":"mb-8","children":[["$","span",null,{"className":"inline-block text-[10px] font-semibold tracking-[.1em] uppercase text-[#C9832E] bg-[rgba(201,131,46,.1)] px-3 py-1 rounded-full mb-3","children":"Eğitim"}],["$","h1",null,{"className":"font-serif text-[clamp(26px,4vw,42px)] font-semibold text-[#2F2622] mb-4 leading-tight","children":"Köpek Eğitiminin Temelleri: Evde Nasıl Başlanır?"}],["$","div",null,{"className":"flex flex-wrap items-center gap-4 text-sm text-[#9A9188]","children":[["$","span",null,{"children":"✍️ Patıpetra Editörü"}],["$","span",null,{"children":["📅 ","10 Mart 2026"]}],["$","span",null,{"children":["⏱ ",9," dakika okuma"]}]]}]]}],["$","div",null,{"className":"bg-[#F4EBDD] border-l-4 border-[#C9832E] rounded-r-[16px] px-5 py-4 mb-8","children":["$","p",null,{"className":"text-[15px] font-medium text-[#5C4A32] leading-relaxed italic","children":"Temel komutları öğretmek için kanıtlanmış pozitif pekiştirme yöntemleri."}]}],["$","div",null,{"className":"prose max-w-none text-[15px]","children":[["$","p","0",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Köpek eğitimi, ne kadar erken başlanırsa o kadar kolay ilerler. Ancak bu \"yaşlı köpek yeni numara öğrenemez\" demek değildir; sabır ve doğru tekniklerle her yaştaki köpek eğitilebilir. Bu rehberde pozitif pekiştirme yöntemiyle temel komutları nasıl öğreteceğinizi adım adım anlatıyoruz."]}],null,["$","h2","2",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"Pozitif Pekiştirme Nedir?"}],null,["$","p","4",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Pozitif pekiştirme, köpeğinizin doğru davranışı yaptığında ödül (mama, oyun, övgü) vermesi esasına dayanır. Ceza temelli yöntemler hem etkisiz hem de köpek-sahip ilişkisine zarar vericidir. Modern köpek eğitimi bilimi, pozitif pekiştirmenin çok daha hızlı ve kalıcı sonuçlar verdiğini göstermektedir."]}],null,["$","h2","6",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"Eğitime Başlamadan Önce"}],null,["$","p","8",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["",["$","strong","1",{"className":"font-semibold text-[#2F2622]","children":"Doğru ödül seçimi:"}]," Köpeğinizin en çok neyi sevdiğini öğrenin. Bazı köpekler mama için, bazıları oyun için, bazıları ise övgü için çalışır."]}],null,["$","p","10",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["",["$","strong","1",{"className":"font-semibold text-[#2F2622]","children":"Zamanlama:"}]," Ödül, davranış gerçekleştikten sonraki 1-2 saniye içinde verilmelidir. Gecikmeli ödül, köpeğin hangi davranışının ödüllendirildiğini anlamamasına yol açar."]}],null,["$","p","12",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["",["$","strong","1",{"className":"font-semibold text-[#2F2622]","children":"Seans süresi:"}]," Günde 2-3 kez, 5-10 dakikalık kısa seanslar daha verimlidir. Uzun seanslar köpeği yorar ve dikkatini dağıtır."]}],null,["$","h2","14",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"OTUR Komutu"}],null,["$","p","16",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Otur, tüm komutların temelidir. Öğretmek en kolay komutlardan biridir."]}],null,["$","p","18",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["1. Elinizde ödül tutun ve köpeğinizin burnunun önüne getirin"]}],["$","p","19",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["2. Elinizi yavaşça başının üstüne ve arkasına doğru götürün"]}],["$","p","20",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["3. Köpek ödülü takip ederken otomatik olarak oturacaktır"]}],["$","p","21",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["4. Oturur oturmaz \"OTUR\" deyin ve ödülü verin"]}],["$","p","22",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["5. 10-15 tekrar sonra el hareketi olmadan komutla deneyin"]}],null,["$","h2","24",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"DUR Komutu"}],null,["$","p","26",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Dur komutu güvenlik açısından kritiktir; özellikle trafik yanında ya da tehlikeli durumlarda hayat kurtarabilir."]}],null,["$","p","28",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["1. Köpeğiniz otururken öne iki adım atın"]}],["$","p","29",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["2. Elinizi açık tutarak \"DUR\" deyin"]}],["$","p","30",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["3. 3 saniye bekleyin, kalmazsa geri dönün ve baştan başlayın"]}],["$","p","31",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["4. Başarılı olursa ödülü verin"]}],["$","p","32",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["5. Süreyi kademeli olarak artırın: 3 saniye → 5 saniye → 10 saniye"]}],null,["$","h2","34",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"GEL Komutu"}],null,["$","p","36",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Gel komutu, köpeğinizin her koşulda yanınıza gelmesini sağlar. Bu komutun her uygulamasının pozitif bitmesi şarttır."]}],null,["$","p","38",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["1. Köpeğinizden birkaç adım uzaklaşın"]}],["$","p","39",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["2. Çömelip \"GEL\" deyin ve coşkuyla el hareketi yapın"]}],["$","p","40",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["3. Geldiğinde bol ödül ve övgüyle karşılayın"]}],["$","p","41",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["4. Mesafeyi kademeli olarak artırın"]}],null,["$","p","43",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Uyarı: Köpek geldiğinde asla azarlamayın. Bu, gelme davranışını olumsuz koşullandırır."]}],null,["$","h2","45",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"YATIR Komutu"}],null,["$","p","47",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Yatır, otur komutunu öğrenen köpekler için nispeten kolaydır."]}],null,["$","p","49",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["1. Köpek otururken ödülü burnunun önüne getirin"]}],["$","p","50",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["2. Ödülü yavaşça aşağı ve öne doğru çekin"]}],["$","p","51",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["3. Köpek ödülü takip ederken yere uzanacaktır"]}],["$","p","52",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["4. \"YATIR\" deyin ve ödülü verin"]}],null,["$","h2","54",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"Yaygın Hatalar"}],null,["$","p","56",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["",["$","strong","1",{"className":"font-semibold text-[#2F2622]","children":"Komutları tekrarlamak:"}]," \"Otur, otur, otur!\" demek köpeğe hangi tekrarda oturması gerektiğini öğretir. Komutu bir kez verin."]}],null,["$","p","58",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["",["$","strong","1",{"className":"font-semibold text-[#2F2622]","children":"Eğitim seanslarını çok uzun tutmak:"}]," Yorgunluk öğrenmeyi engeller."]}],null,["$","p","60",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["",["$","strong","1",{"className":"font-semibold text-[#2F2622]","children":"Tutarsız olmak:"}]," Ailenin herkes aynı komutları kullanmalıdır."]}],null,["$","p","62",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["",["$","strong","1",{"className":"font-semibold text-[#2F2622]","children":"Olumsuz duygularla eğitmek:"}]," Sinirli ya da sabırsızken eğitim yapmayın."]}],null,["$","h2","64",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"Ne Zaman Profesyonel Yardım Alınmalı?"}],null,["$","p","66",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Köpeğinizde saldırganlık, aşırı korku ya da yıkıcı davranışlar varsa ve temel eğitim teknikleri işe yaramıyorsa, deneyimli bir köpek eğitmeninden destek almanız gerekebilir. Patıpetra üzerinden onaylı köpek eğitmenlerine ulaşabilirsiniz."]}]]}],["$","div",null,{"className":"mt-8 pt-6 border-t border-[#E3D9C6]","children":["$","div",null,{"className":"flex flex-wrap gap-2","children":[["$","span","Eğitim",{"className":"text-xs bg-[#EDE5D3] text-[#6E5A40] px-3 py-1 rounded-full","children":["#","Eğitim"]}],["$","span","evcil hayvan",{"className":"text-xs bg-[#EDE5D3] text-[#6E5A40] px-3 py-1 rounded-full","children":["#","evcil hayvan"]}],["$","span","pet bakım",{"className":"text-xs bg-[#EDE5D3] text-[#6E5A40] px-3 py-1 rounded-full","children":["#","pet bakım"]}],["$","span","patipetra",{"className":"text-xs bg-[#EDE5D3] text-[#6E5A40] px-3 py-1 rounded-full","children":["#","patipetra"]}]]}]}],false]}],["$","aside",null,{"className":"hidden lg:block","children":["$","div",null,{"className":"sticky top-[84px] space-y-4","children":[["$","div",null,{"className":"bg-white rounded-[16px] border border-[rgba(196,169,107,.12)] p-5","children":[["$","h3",null,{"className":"font-serif text-base font-semibold text-[#2F2622] mb-3","children":"📋 Hızlı Erişim"}],["$","div",null,{"className":"space-y-2","children":[["$","div","0",{"className":"text-xs text-[#7A7368] hover:text-[#