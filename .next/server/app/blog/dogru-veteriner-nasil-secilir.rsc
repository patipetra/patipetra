lassName":"absolute top-[84px] left-4 sm:left-8","children":["$","$L3",null,{"href":"/blog","className":"text-sm text-white/70 hover:text-white transition-colors","children":"← Blog'a Dön"}]}]]}],["$","div",null,{"className":"max-w-[1100px] mx-auto px-4 sm:px-8 py-10","children":["$","div",null,{"className":"grid lg:grid-cols-[1fr_.32fr] gap-10","children":[["$","article",null,{"children":[["$","div",null,{"className":"mb-8","children":[["$","span",null,{"className":"inline-block text-[10px] font-semibold tracking-[.1em] uppercase text-[#C9832E] bg-[rgba(201,131,46,.1)] px-3 py-1 rounded-full mb-3","children":"Rehber"}],["$","h1",null,{"className":"font-serif text-[clamp(26px,4vw,42px)] font-semibold text-[#2F2622] mb-4 leading-tight","children":"Petiniz İçin Doğru Veterineri Nasıl Seçersiniz?"}],["$","div",null,{"className":"flex flex-wrap items-center gap-4 text-sm text-[#9A9188]","children":[["$","span",null,{"children":"✍️ Patıpetra Editörü"}],["$","span",null,{"children":["📅 ","28 Şubat 2026"]}],["$","span",null,{"children":["⏱ ",7," dakika okuma"]}]]}]]}],["$","div",null,{"className":"bg-[#F4EBDD] border-l-4 border-[#C9832E] rounded-r-[16px] px-5 py-4 mb-8","children":["$","p",null,{"className":"text-[15px] font-medium text-[#5C4A32] leading-relaxed italic","children":"Veteriner seçimi için 8 temel kriter, sormanız gereken sorular ve ipuçları."}]}],["$","div",null,{"className":"prose max-w-none text-[15px]","children":[["$","p","0",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Evcil hayvanınız için doğru veterineri bulmak, sağlıklı ve uzun bir ilişkinin temelidir. İyi bir veteriner yalnızca hastalıkları tedavi etmez; koruyucu sağlık hizmetleri sunar, sorularınızı sabırla yanıtlar ve hayvanınızla sağlıklı bir ilişki kurar."]}],null,["$","h2","2",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"1. Uzmanlık Alanını Kontrol Edin"}],null,["$","p","4",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Her veteriner her hayvan türünde uzman değildir. Köpek ve kedi klinikleri en yaygın olsa da egzotik hayvanlar (tavşan, papağan, hamster, sürüngen) için özel veteriner arayışına girmeniz gerekebilir."]}],null,["$","p","6",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Veterinerin hangi konularda daha deneyimli olduğunu sormaktan çekinmeyin: Diş sağlığı, ortopedi, dermatoloji, onkoloji gibi alanlarda ek eğitim almış veterinerler de bulunmaktadır."]}],null,["$","h2","8",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"2. Klinikteki Ekipmanlar"}],null,["$","p","10",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Modern bir veteriner kliniği şu ekipmanlara sahip olmalıdır:"]}],["$","li","11",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Dijital röntgen cihazı"}],["$","li","12",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Ultrason cihazı"}],["$","li","13",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Kan tahlil laboratuvarı (ya da hızlı sonuç için anlaşmalı lab)"}],["$","li","14",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Steril ameliyathane"}],["$","li","15",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Yatış ünitesi"}],null,["$","p","17",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Bu ekipmanların varlığı hem teşhis kalitesini artırır hem de acil durumlarda kıymetli zaman kazandırır."]}],null,["$","h2","19",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"3. İletişim Kalitesi"}],null,["$","p","21",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["İyi bir veteriner:"]}],["$","li","22",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Tanıyı ve tedaviyi anlaşılır bir dille açıklar"}],["$","li","23",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Alternatif tedavi seçeneklerini sunar"}],["$","li","24",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Maliyet konusunda önceden şeffaf bilgi verir"}],["$","li","25",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Sorularınıza sabırla yanıt verir"}],null,["$","p","27",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Veteriner muayene sırasında sürekli ekrana bakıyor, sizi dinlemiyor ya da sorularınıza cevap vermekten kaçınıyorsa bu iyi bir işaret değildir."]}],null,["$","h2","29",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"4. Temizlik ve Hijyen"}],null,["$","p","31",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Kliniğin genel temizliği sağlık güvencesinin görsel bir yansımasıdır. Yüzeylerin temiz olması, keskin koku bulunmaması ve kullanılan ekipmanların steril görünmesi dikkat edilmesi gereken noktalardır."]}],null,["$","h2","33",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"5. Acil Durumlarda Ulaşılabilirlik"}],null,["$","p","35",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Evcil hayvanlar her zaman mesai saatlerinde hastalanmaz. Kliniğin nöbet uygulaması var mı ya da acil durumlarda yönlendirebilecekleri bir klinikle anlaşmaları mevcut mu? Bunu önceden öğrenin."]}],null,["$","h2","37",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"6. Fiyat Şeffaflığı"}],null,["$","p","39",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Muayene, aşı ve temel işlemler için yaklaşık ücretleri önceden sorabilirsiniz. Şeffaf fiyatlandırma yapan klinikler, güvenilirlik açısından olumlu bir işarettir."]}],null,["$","h2","41",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"7. Hayvanınızın Tepkisi"}],null,["$","p","43",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Hayvanınız veterinere gitmeyi tamamen reddetmesi, klinikte aşırı panik yaşaması ya da muayene sırasında veterinere karşı olağandışı saldırgan davranması bir işaret olabilir. Ancak bu bazen hayvandan kaynaklanıyor da olabilir; bu nedenle sıklıkla yaşanıyorsa değerlendirmeye alın."]}],null,["$","h2","45",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"8. Tavsiyeler ve Yorumlar"}],null,["$","p","47",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Çevrenizden aldığınız tavsiyeler hâlâ en güvenilir bilgi kaynaklarından biridir. Patıpetra üzerinden de doğrulanmış veterinerler için yorumları inceleyebilirsiniz."]}],null,["$","h2","49",{"className":"font-serif text-[clamp(20px,2.5vw,26px)] font-semibold text-[#2F2622] mt-8 mb-4","children":"İlk Muayeneyi Deneme Fırsatı Olarak Görün"}],null,["$","p","51",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["İlk muayeneden sonra kendinize şu soruları sorun:"]}],["$","li","52",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Kendimi iyi dinlenilmiş hissettim mi?"}],["$","li","53",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Tanı anlaşılır biçimde açıklandı mı?"}],["$","li","54",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Fiyatlar makul müydi?"}],["$","li","55",{"className":"ml-5 mb-1 list-disc text-[#5C4A32]","children":"Kliniğe güvenebildim mi?"}],null,["$","p","57",{"className":"mb-4 leading-[1.95] text-[#5C4A32]","children":["Yanıtlar olumlu değilse farklı bir veteriner denemekten çekinmeyin. Evcil hayvanınızın sağlığı en doğru tercih hakkını hak eder."]}]]}],["$","div",null,{"className":"mt-8 pt-6 border-t border-[#E3D9C6]","children":["$","div",null,{"className":"flex flex-wrap gap-2","children":[["$","span","Rehber",{"className":"text-xs bg-[#EDE5D3] text-[#6E5A40] px-3 py-1 rounded-full","children":["#","Rehber"]}],["$","span","evcil hayvan",{"className":"text-xs bg-[#EDE5D3] text-[#6E5A40]