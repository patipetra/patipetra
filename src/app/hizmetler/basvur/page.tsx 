'use client';
import { useState, useEffect, useRef } from 'react';
import { useRouter } from 'next/navigation';
import Link from 'next/link';
import Navbar from '@/components/layout/Navbar';
import Footer from '@/components/layout/Footer';
import { onAuthChange } from '@/lib/auth';
import { createService, uploadServiceImage, slugify, PLAN_PRICES, type ServiceType, type PlanType, type ServicePrice } from '@/lib/services';
import { CITIES_81 } from '@/data/cities';
import type { User } from 'firebase/auth';

const SERVICE_TYPES: {val:ServiceType; label:string; icon:string; desc:string}[] = [
  {val:'groomer', label:'Pet Kuaför', icon:'✂️', desc:'Tıraş, banyo, tırnak kesimi'},
  {val:'hotel',   label:'Pet Otel',   icon:'🏨', desc:'Günlük & haftalık konaklama'},
  {val:'trainer', label:'Pet Eğitmen',icon:'🎓', desc:'Temel komut ve davranış eğitimi'},
];

export default function BasvurPage() {
  const router  = useRouter();
  const [user,    setUser]    = useState<User|null>(null);
  const [loading, setLoading] = useState(true);
  const [step,    setStep]    = useState(1); // 1: type & plan, 2: bilgiler, 3: fiyatlar & fotoğraf
  const [saving,  setSaving]  = useState(false);
  const [success, setSuccess] = useState(false);
  const [error,   setError]   = useState('');

  // Form state
  const [type,    setType]    = useState<ServiceType>('groomer');
  const [plan,    setPlan]    = useState<PlanType>('basic');
  const [bizName, setBizName] = useState('');
  const [desc,    setDesc]    = useState('');
  const [city,    setCity]    = useState('');
  const [district,setDistrict]= useState('');
  const [address, setAddress] = useState('');
  const [phone,   setPhone]   = useState('');
  const [email,   setEmail]   = useState('');
  const [website, setWebsite] = useState('');
  const [instagram,setInstagram]=useState('');
  const [hours,   setHours]   = useState('Hafta içi 09:00-18:00');
  const [prices,  setPrices]  = useState<ServicePrice[]>([{name:'',price:0,desc:''}]);
  const [cover,   setCover]   = useState<File|null>(null);
  const [coverPreview,setCoverPreview]=useState('');
  const [images,  setImages]  = useState<File[]>([]);
  const [imagePreviews,setImagePreviews]=useState<string[]>([]);
  const coverRef = useRef<HTMLInputElement>(null);
  const imagesRef = useRef<HTMLInputElement>(null);

  useEffect(() => {
    const unsub = onAuthChange(u => {
      if (!u) { router.push('/giris?redirect=/hizmetler/basvur'); return; }
      setUser(u);
      setEmail(u.email||'');
      setLoading(false);
    });
    return () => unsub();
  }, [router]);

  function addPrice() { setPrices(p=>[...p,{name:'',price:0,desc:''}]); }
  function removePrice(i:number) { setPrices(p=>p.filter((_,idx)=>idx!==i)); }
  function updatePrice(i:number, field:keyof ServicePrice, val:string|number) {
    setPrices(p=>p.map((pr,idx)=>idx===i?{...pr,[field]:val}:pr));
  }

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault(); setError('');
    if (!bizName||!desc||!city||!phone) { setError('Zorunlu alanları doldurun.'); return; }
    if (!user) return;
    setSaving(true);
    try {
      const tempId = `svc_${Date.now()}`;
      let coverUrl = '';
      if (cover) coverUrl = await uploadServiceImage(user.uid, tempId+'_cover', cover);
      const imageUrls: string[] = [];
      for (const img of images) {
        const url = await uploadServiceImage(user.uid, tempId, img);
        imageUrls.push(url);
      }
      await createService({
        ownerId:      user.uid,
        ownerName:    user.displayName || user.email?.split('@')[0] || '',
        ownerEmail:   user.email || '',
        ownerPhone:   phone,
        type, plan,
        businessName: bizName,
        slug:         slugify(bizName) + '-' + Date.now().toString().slice(-4),
        description:  desc,
        city, district, address, phone, email, website, instagram,
        workingHours: hours,
        coverUrl, imageUrls,
        prices: prices.filter(p=>p.name),
      });
      setSuccess(true);
    } catch(err:any) { setError('Hata: '+err.message); }
    finally { setSaving(false); }
  }

  if (loading) return (
    <>
      <Navbar/>
      <div className="min-h-screen bg-[#F7F2EA] flex items-center justify-center pt-[68px]">
        <div className="w-8 h-8 border-2 border-[#C9832E] border-t-transparent rounded-full animate-spin"/>
      </div>
    </>
  );

  if (success) return (
    <>
      <Navbar/>
      <div className="min-h-screen bg-[#F7F2EA] flex items-center justify-center pt-[68px]">
        <div className="text-center p-8 max-w-md">
          <div className="text-6xl mb-4">🎉</div>
          <h2 className="font-serif text-3xl font-semibold text-[#2F2622] mb-3">Başvurunuz Alındı!</h2>
          <p className="text-[#7A7368] mb-3 leading-relaxed">İşletmeniz admin tarafından incelendikten sonra yayına alınacak.</p>
          <p className="text-sm text-[#9A9188] mb-8">Ödeme bilgileri için <strong className="text-[#5C4A32]">patipetraa1@gmail.com</strong> adresine e-posta gönderilecek.</p>
          <Link href="/hizmetler" className="inline-flex bg-[#C9832E] text-white text-sm font-semibold px-6 py-3 rounded-full hover:bg-[#b87523] transition-colors">
            Hizmetlere Dön
          </Link>
        </div>
      </div>
    </>
  );

  return (
    <>
      <Navbar/>
      <main className="min-h-screen bg-[#F7F2EA] pt-[108px] pb-20">
        <div className="max-w-[680px] mx-auto px-4">
          <Link href="/hizmetler" className="text-sm text-[#7A7368] hover:text-[#2F2622] mb-6 inline-flex items-center gap-1">← Hizmetlere Dön</Link>

          <div className="mb-6">
            <h1 className="font-serif text-2xl font-semibold text-[#2F2622] mb-1">İşletme Başvurusu 🏪</h1>
            <p className="text-sm text-[#7A7368]">Bilgilerinizi doldurun, admin onayından sonra yayına girecek.</p>
          </div>

          {/* Adım göstergesi */}
          <div className="flex items-center gap-2 mb-6">
            {[1,2,3].map(s=>(
              <div key={s} className="flex items-center gap-2">
                <div className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-semibold transition-all ${step>=s?'bg-[#5C4A32] text-white':'bg-[#EDE5D3] text-[#9A9188]'}`}>{s}</div>
                {s<3&&<div className={`flex-1 h-[2px] w-16 rounded transition-all ${step>s?'bg-[#5C4A32]':'bg-[#E3D9C6]'}`}/>}
              </div>
            ))}
            <div className="ml-2 text-xs text-[#7A7368]">
              {step===1?'Tür & Plan':step===2?'İşletme Bilgileri':'Fiyatlar & Fotoğraflar'}
            </div>
          </div>

          {error && <div className="bg-red-50 border border-red-200 text-red-700 text-sm rounded-[12px] px-4 py-3 mb-4">{error}</div>}

          <form onSubmit={handleSubmit}>
            {/* ADIM 1: Tür & Plan */}
            {step===1 && (
              <div className="space-y-5">
                <div className="bg-white rounded-[20px] border border-[rgba(196,169,107,.12)] p-6">
                  <h3 className="font-semibold text-[#2F2622] mb-4">Hizmet Türü</h3>
                  <div className="grid gap-3">
                    {SERVICE_TYPES.map(t=>(
                      <button key={t.val} type="button" onClick={()=>setType(t.val)}
                        className={`flex items-center gap-4 p-4 rounded-[14px] border-[1.5px] text-left transition-all ${type===t.val?'border-[#C9832E] bg-[rgba(201,131,46,.05)]':'border-[#E3D9C6] hover:border-[#8B7355]'}`}>
                        <div className="text-3xl">{t.icon}</div>
                        <div>
                          <div className="font-semibold text-[#2F2622]">{t.label}</div>
                          <div className="text-xs text-[#7A7368]">{t.desc}</div>
                        </div>
                        {type===t.val&&<div className="ml-auto w-5 h-5 rounded-full bg-[#C9832E] flex items-center justify-center text-white text-xs">✓</div>}
                      </button>
                    ))}
                  </div>
                </div>

                <div className="bg-white rounded-[20px] border border-[rgba(196,169,107,.12)] p-6">
                  <h3 className="font-semibold text-[#2F2622] mb-4">Üyelik Planı</h3>
                  <div className="grid sm:grid-cols-2 gap-3">
                    {(['basic','premium'] as PlanType[]).map(p=>(
                      <button key={p} type="button" onClick={()=>setPlan(p)}
                        className={`p-5 rounded-[16px] border-[1.5px] text-left transition-all ${plan===p?p==='premium'?'border-[#C9832E] bg-[rgba(201,131,46,.05)]':'border-[#5C4A32] bg-[rgba(92,74,50,.03)]':'border-[#E3D9C6] hover:border-[#8B7355]'}`}>
                        <div className="font-semibold text-[#2F2622] mb-1">{PLAN_PRICES[p].label}</div>
                        <div className={`text-xl font-serif font-semibold mb-3 ${p==='premium'?'text-[#C9832E]':'text-[#5C4A32]'}`}>{PLAN_PRICES[p].price}</div>
                        <div className="flex flex-col gap-1">
                          {PLAN_PRICES[p].features.map(f=>(
                            <div key={f} className="text-xs text-[#5C4A32] flex items-center gap-1">
                              <span className="text-[#6B7C5C]">✓</span> {f}
                            </div>
                          ))}
                        </div>
                        {p==='premium'&&<div className="mt-3 text-[10px] font-semibold text-[#C9832E] bg-[rgba(201,131,46,.1)] px-2 py-1 rounded-full inline-block">En Popüler</div>}
                      </button>
                    ))}
                  </div>
                  <p className="text-xs text-[#9A9188] mt-4">💳 Ödeme bilgileri başvuru sonrası e-posta ile iletilecek.</p>
                </div>

                <button type="button" onClick={()=>setStep(2)}
                  className="w-full py-[13px] rounded-[14px] bg-[#5C4A32] text-white text-[15px] font-medium hover:bg-[#2F2622] transition-all">
                  Devam Et →
                </button>
              </div>
            )}

            {/* ADIM 2: İşletme bilgileri */}
            {step===2 && (
              <div className="space-y-4">
                <div className="bg-white rounded-[20px] border border-[rgba(196,169,107,.12)] p-6">
                  <h3 className="font-semibold text-[#2F2622] mb-4">İşletme Bilgileri</h3>
                  <div className="space-y-3">
                    <div>
                      <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">İşletme Adı *</label>
                      <input value={bizName} onChange={e=>setBizName(e.target.value)} placeholder="Pati Bakım Salonu" required
                        className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                    </div>
                    <div>
                      <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">Açıklama *</label>
                      <textarea value={desc} onChange={e=>setDesc(e.target.value)} placeholder="İşletmenizi kısaca tanıtın…" rows={4} required
                        className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all resize-none"/>
                    </div>
                    <div className="grid grid-cols-2 gap-3">
                      <div>
                        <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">Şehir *</label>
                        <select value={city} onChange={e=>setCity(e.target.value)} required
                          className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all">
                          <option value="">Seçin…</option>
                          {CITIES_81.map(c=><option key={c} value={c}>{c}</option>)}
                        </select>
                      </div>
                      <div>
                        <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">İlçe</label>
                        <input value={district} onChange={e=>setDistrict(e.target.value)} placeholder="Çankaya"
                          className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                      </div>
                    </div>
                    <div>
                      <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">Adres</label>
                      <input value={address} onChange={e=>setAddress(e.target.value)} placeholder="Tam adres"
                        className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                    </div>
                    <div className="grid grid-cols-2 gap-3">
                      <div>
                        <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">Telefon *</label>
                        <input value={phone} onChange={e=>setPhone(e.target.value)} placeholder="05XX XXX XX XX" required
                          className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                      </div>
                      <div>
                        <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">E-posta</label>
                        <input value={email} onChange={e=>setEmail(e.target.value)} placeholder="isletme@email.com" type="email"
                          className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                      </div>
                    </div>
                    <div className="grid grid-cols-2 gap-3">
                      <div>
                        <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">Website</label>
                        <input value={website} onChange={e=>setWebsite(e.target.value)} placeholder="https://…"
                          className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                      </div>
                      <div>
                        <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">Instagram</label>
                        <input value={instagram} onChange={e=>setInstagram(e.target.value)} placeholder="@kullanici_adi"
                          className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                      </div>
                    </div>
                    <div>
                      <label className="block text-[10px] font-medium tracking-[.1em] uppercase text-[#7A7368] mb-1">Çalışma Saatleri</label>
                      <input value={hours} onChange={e=>setHours(e.target.value)} placeholder="Hafta içi 09:00-18:00"
                        className="w-full px-3 py-[11px] rounded-[12px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                    </div>
                  </div>
                </div>
                <div className="flex gap-3">
                  <button type="button" onClick={()=>setStep(1)} className="flex-1 py-[13px] rounded-[14px] border border-[#8B7355] text-[#5C4A32] text-[15px] font-medium hover:bg-[#5C4A32] hover:text-white transition-all">← Geri</button>
                  <button type="button" onClick={()=>setStep(3)} className="flex-1 py-[13px] rounded-[14px] bg-[#5C4A32] text-white text-[15px] font-medium hover:bg-[#2F2622] transition-all">Devam Et →</button>
                </div>
              </div>
            )}

            {/* ADIM 3: Fiyatlar & Fotoğraflar */}
            {step===3 && (
              <div className="space-y-4">
                {/* Fiyat listesi */}
                <div className="bg-white rounded-[20px] border border-[rgba(196,169,107,.12)] p-6">
                  <div className="flex items-center justify-between mb-4">
                    <h3 className="font-semibold text-[#2F2622]">Hizmet Fiyatları</h3>
                    <button type="button" onClick={addPrice} className="text-sm text-[#C9832E] hover:underline">+ Ekle</button>
                  </div>
                  <div className="space-y-3">
                    {prices.map((p,i)=>(
                      <div key={i} className="flex gap-2 items-start">
                        <div className="flex-1 grid grid-cols-3 gap-2">
                          <input value={p.name} onChange={e=>updatePrice(i,'name',e.target.value)} placeholder="Hizmet adı" className="px-3 py-2 rounded-[10px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                          <input type="number" value={p.price||''} onChange={e=>updatePrice(i,'price',Number(e.target.value))} placeholder="₺ Fiyat" className="px-3 py-2 rounded-[10px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                          <input value={p.desc||''} onChange={e=>updatePrice(i,'desc',e.target.value)} placeholder="Açıklama" className="px-3 py-2 rounded-[10px] border-[1.5px] border-[#E3D9C6] bg-[#F7F2EA] text-sm focus:outline-none focus:border-[#C9832E] transition-all"/>
                        </div>
                        {prices.length>1&&<button type="button" onClick={()=>removePrice(i)} className="text-red-400 hover:text-red-600 text-sm mt-2">🗑</button>}
                      </div>
                    ))}
                  </div>
                </div>

                {/* Kapak fotoğrafı */}
                <div className="bg-white rounded-[20px] border border-[rgba(196,169,107,.12)] p-6">
                  <h3 className="font-semibold text-[#2F2622] mb-4">Kapak Fotoğrafı</h3>
                  <div onClick={()=>coverRef.current?.click()}
                    className="w-full h-40 rounded-[14px] border-2 border-dashed border-[#E3D9C6] flex items-center justify-center cursor-pointer hover:border-[#C9832E] hover:bg-[#F5EDD4] transition-all overflow-hidden">
                    {coverPreview
                      // eslint-disable-next-line @next/next/no-img-element
                      ? <img src={coverPreview} alt="" className="w-full h-full object-cover"/>
                      : <div className="text-center"><div className="text-3xl mb-2">📷</div><div className="text-sm text-[#7A7368]">Kapak fotoğrafı seç</div></div>
                    }
                  </div>
                  <input ref={coverRef} type="file" accept="image/*" className="hidden" onChange={e=>{const f=e.target.files?.[0];if(f){setCover(f);setCoverPreview(URL.createObjectURL(f))}}}/>
                </div>

                {/* Galeri */}
                <div className="bg-white rounded-[20px] border border-[rgba(196,169,107,.12)] p-6">
                  <h3 className="font-semibold text-[#2F2622] mb-4">Fotoğraf Galerisi (max {plan==='premium'?20:5})</h3>
                  <div className="flex flex-wrap gap-2 mb-3">
                    {imagePreviews.map((p,i)=>(
                      <div key={i} className="relative w-20 h-20 rounded-[10px] overflow-hidden border border-[#E3D9C6]">
                        {/* eslint-disable-next-line @next/next/no-img-element */}
                        <img src={p} alt="" className="w-full h-full object-cover"/>
                        <button type="button" onClick={()=>{setImages(prev=>prev.filter((_,idx)=>idx!==i));setImagePreviews(prev=>prev.filter((_,idx)=>idx!==i));}}
                          className="absolute top-1 right-1 w-5 h-5 bg-red-500 text-white rounded-full text-[10px] flex items-center justify-center">✕</button>
                      </div>
                    ))}
                    {images.length < (plan==='premium'?20:5) && (
                      <button type="button" onClick={()=>imagesRef.current?.click()}
                        className="w-20 h-20 rounded-[10px] border-2 border-dashed border-[#E3D9C6] flex flex-col items-center justify-center hover:border-[#C9832E] hover:bg-[#F5EDD4] transition-all text-[#7A7368]">
                        <span className="text-2xl">+</span>
                        <span className="text-[9px]">Ekle</span>
                      </button>
                    )}
                  </div>
                  <input ref={imagesRef} type="file" accept="image/*" multiple className="hidden" onChange={e=>{
                    const files = Array.from(e.target.files||[]).slice(0,(plan==='premium'?20:5)-images.length);
                    setImages(prev=>[...prev,...files]);
                    setImagePreviews(prev=>[...prev,...files.map(f=>URL.createObjectURL(f))]);
                  }}/>
                </div>

                <div className="bg-[rgba(201,131,46,.06)] border border-[rgba(201,131,46,.2)] rounded-[12px] px-4 py-3 text-sm text-[#8B7355]">
                  ℹ️ Başvurunuz admin tarafından incelendikten sonra ödeme bilgileri e-posta ile iletilecek ve işletmeniz yayına alınacak.
                </div>

                <div className="flex gap-3">
                  <button type="button" onClick={()=>setStep(2)} className="flex-1 py-[13px] rounded-[14px] border border-[#8B7355] text-[#5C4A32] text-[15px] font-medium hover:bg-[#5C4A32] hover:text-white transition-all">← Geri</button>
                  <button type="submit" disabled={saving} className="flex-1 py-[13px] rounded-[14px] bg-[#C9832E] text-white text-[15px] font-medium hover:bg-[#b87523] transition-all disabled:opacity-60">
                    {saving?'Gönderiliyor…':'Başvuruyu Gönder 🚀'}
                  </button>
                </div>
              </div>
            )}
          </form>
        </div>
      </main>
      <Footer/>
    </>
  );
}
